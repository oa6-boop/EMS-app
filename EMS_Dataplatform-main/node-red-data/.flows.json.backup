    {
        "id": "48d3021c0f4bb148",
        "type": "function",
        "z": "a9bae36478b0d10e",
        "name": "Énergie Totale Line-1 (kWh)",
        "func": "var total = (global.get('energy_kwh_EXTRACTION')     || 0)\n          + (global.get('energy_kwh_Washing')         || 0)\n          + (global.get('energy_kwh_Flotation')       || 0)\n          + (global.get('energy_kwh_Utilities')       || 0)\n          + (global.get('energy_kwh_Storage_Handling')|| 0);\nglobal.set('line_total_energy', total);\nmsg.payload = +total.toFixed(3);\nreturn msg;\n",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
