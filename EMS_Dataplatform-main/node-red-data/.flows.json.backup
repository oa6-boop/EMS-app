        "func": "var v = msg.payload || 0;\ncontext.set('P_7', v);\nflow.set('P_7', v);\nflow.set('P_Storage_Handling_7', v);\nglobal.set('P_7', v);\nglobal.set('P_Storage_Handling_7', v);\nreturn msg;",
