        "type": "function",
        "z": "3983825debe3736c",
        "name": "Store PF2",
        "func": "var _pf = (msg.payload||90)/100;\ncontext.set('PF_2', _pf);\nflow.set('PF_2', _pf);\nreturn msg;",
