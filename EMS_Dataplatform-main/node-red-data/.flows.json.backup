    {
        "id": "45d8efe576968818",
        "type": "function",
        "z": "e446fb4ecf531d48",
        "name": "function 1",
        "func": "const unitId = msg.payload.unitid || msg.unitid || 1;\nconst raw = msg.payload.data || msg.payload;\n\nmsg.topic = `ems/meter/${unitId}`;\nmsg.payload = {\n    device_id:    `PM-00${unitId}`,\n    device_name:  `Power Meter ${unitId}`,\n    timestamp:    new Date().toISOString(),\n    measurements: {\n        frequency_Hz:      raw[0] / 100,\n        voltage_V:         raw[1] / 10,\n        current_A:         raw[2] / 10,\n        power_factor:      raw[3] / 100,\n        thd_voltage_pct:   raw[4] / 10,\n        thd_current_pct:   raw[5] / 10,\n        active_energy_kWh: raw[6]\n    }\n};\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
        "y": 200,
        "wires": [
            [
                "ad3a94292d0b38ae"
            ]
        ]
    },
