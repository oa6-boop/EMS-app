        "broker": "17a6c5a9c18f3664",
        "x": 1130,
        "y": 1770,
        "wires": []
    },
    {
        "id": "d8cba48c21199e82",
        "type": "inject",
        "z": "3983825debe3736c",
        "name": "Calc Q,S PM2",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "5",
        "crontab": "",
        "once": true,
        "onceDelay": "0.5",
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 80,
        "y": 1800,
        "wires": [
            [
                "6e481e76c268858f"
            ]
        ]
    },
    {
        "id": "6e481e76c268858f",
        "type": "function",
        "z": "3983825debe3736c",
        "name": "PQS PM2",
        "func": "var P  = flow.get('P_2') || 0;\nvar PF = flow.get('PF_2') || 0.9;\nvar S  = PF > 0 ? P / PF : 0;\nvar Q  = Math.sqrt(Math.max(0, S*S - P*P));\n// Calcul énergie consommée (kWh) pour ce PM, dt=5s\nvar dt = 5 / 3600;\nvar kwh = (global.get('energy_kwh_PM2') || 0) + P * dt;\nglobal.set('energy_kwh_PM2', kwh);\nvar out = {P: +P.toFixed(2), Q: +Q.toFixed(2), S: +S.toFixed(2)};\nreturn [\n  {payload: out.P, topic:'P'},\n  {payload: out.Q, topic:'Q'},\n  {payload: out.S, topic:'S'},\n  {payload: +kwh.toFixed(3), topic:'Energy_kWh'}\n];",
        "outputs": 4,
        "timeout": "",
