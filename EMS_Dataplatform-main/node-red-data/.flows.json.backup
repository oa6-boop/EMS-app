    {
        "id": "096c9fe6f75b9c71",
        "type": "inject",
        "z": "a88fb1713c1d4fee",
        "name": "Calc Q,S PM5",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "5",
        "crontab": "",
        "once": true,
        "onceDelay": "0.5",
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 80,
        "y": 1855,
        "wires": [
            [
                "c2c7c1642a19629f"
            ]
        ]
    },
    {
        "id": "c2c7c1642a19629f",
        "type": "function",
        "z": "a88fb1713c1d4fee",
        "name": "PQS PM5",
        "func": "var P  = flow.get('P_5') || 0;\nvar PF = flow.get('PF_5') || 0.9;\nvar S  = PF > 0 ? P / PF : 0;\nvar Q  = Math.sqrt(Math.max(0, S*S - P*P));\n// Calcul énergie consommée (kWh) pour ce PM, dt=5s\nvar dt = 5 / 3600;\nvar kwh = (global.get('energy_kwh_PM5') || 0) + P * dt;\nglobal.set('energy_kwh_PM5', kwh);\nvar out = {P: +P.toFixed(2), Q: +Q.toFixed(2), S: +S.toFixed(2)};\nreturn [\n  {payload: out.P, topic:'P'},\n  {payload: out.Q, topic:'Q'},\n  {payload: out.S, topic:'S'},\n  {payload: +kwh.toFixed(3), topic:'Energy_kWh'}\n];",
        "outputs": 4,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 280,
        "y": 1855,
        "wires": [
            [
                "820af3c79459b76d",
                "d5097ce7f4c20161",
                "d798e435af2d5324"
            ],
            [
                "fc026ec86cfb161f",
                "10ba4add164d95e9",
                "2a3ac84cc14367eb"
            ],
            [
                "7e014709a122e603",
                "a9b49f8a30ede44d",
                "bf616954610c41e5"
            ],
            [
                "23e17d383cc10d3f",
                "d034355fa276f585"
            ]
        ]
    },
