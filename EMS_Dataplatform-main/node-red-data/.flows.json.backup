    {
        "id": "c62740220c7d4366",
        "type": "function",
        "z": "3983825debe3736c",
        "name": "Store P1",
        "func": "var v = msg.payload || 0;\ncontext.set('P_1', v);\nflow.set('P_1', v);\nflow.set('P_EXTRACTION_1', v);\nglobal.set('P_1', v);\nglobal.set('P_EXTRACTION_1', v);\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 790,
