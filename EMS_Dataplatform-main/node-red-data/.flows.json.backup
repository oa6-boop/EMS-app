    {
        "id": "79fea42ba44b3ba1",
        "type": "function",
        "z": "b2f38a1c9c4d89a5",
        "name": "Extract NodeId",
        "func": "// ============================================================\n// Extract NodeId - compatible toutes versions node-red-contrib-opcua\n// ============================================================\nvar nodeIdStr = null;\n\n// Format 1: msg.topic = \"ns=3;i=1117\"  (versions récentes subscribe)\nif (msg.topic && typeof msg.topic === 'string' && msg.topic.indexOf('i=') !== -1) {\n    nodeIdStr = msg.topic;\n}\n// Format 2: msg.payload est un objet avec .nodeId\nelse if (msg.payload && typeof msg.payload === 'object' && msg.payload.nodeId) {\n    var nid = msg.payload.nodeId;\n    nodeIdStr = (typeof nid === 'object' && nid.value) ? String(nid.value) : String(nid);\n}\n// Format 3: msg.nodetype existe (certaines versions)\nelse if (msg.nodetype && msg.nodeId) {\n    nodeIdStr = String(msg.nodeId);\n}\n// Format 4: msg.addressSpaceItems (mode read)\nelse if (msg.addressSpaceItems && msg.addressSpaceItems.length > 0) {\n    var asi = msg.addressSpaceItems[0];\n    nodeIdStr = asi.nodeId || asi.item || '';\n}\n\n// Extraire l'entier après i=\nvar m = nodeIdStr ? String(nodeIdStr).match(/i=(\\d+)/) : null;\nmsg.nodeId = m ? parseInt(m[1]) : 0;\n\n// Aplatir la valeur payload\nif (msg.payload !== null && typeof msg.payload === 'object') {\n    if (msg.payload.value !== undefined)       msg.payload = msg.payload.value;\n    else if (msg.payload.Value !== undefined)  msg.payload = msg.payload.Value;\n}\n\n// Debug: log dans la console Node-RED si nodeId = 0\nif (msg.nodeId === 0) {\n    node.warn(\"NodeId non trouvé - topic: \" + JSON.stringify(msg.topic) + \n              \" | payload keys: \" + JSON.stringify(Object.keys(msg.payload || {})) +\n              \" | payload sample: \" + JSON.stringify(msg.payload).substring(0, 200));\n}\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 500,
        "y": 60,
        "wires": [
            [
                "34214f75a58c1a2f"
            ]
        ]
    },
