    {
        "id": "bb8546287dc8c0e1",
        "type": "inject",
        "z": "3983825debe3736c",
        "name": "Calc Q,S PM1",
        "props": [
            {
                "p": "payload"
            },
            {
                "p": "topic",
                "vt": "str"
            }
        ],
        "repeat": "5",
        "crontab": "",
        "once": true,
        "onceDelay": "0.5",
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 300,
        "y": 780,
        "wires": [
            [
                "f6cae3e664ce08d4"
            ]
        ]
    },
    {
        "id": "f6cae3e664ce08d4",
        "type": "function",
        "z": "3983825debe3736c",
        "name": "Q§S CALCULS",
        "func": "var P  = flow.get('P_1') || 0;\nvar PF = flow.get('PF_1') || 0.9;\nvar S  = PF > 0 ? P / PF : 0;\nvar Q  = Math.sqrt(Math.max(0, S*S - P*P));\n// Calcul énergie consommée (kWh) pour ce PM, dt=5s\nvar dt = 5 / 3600;\nvar kwh = (global.get('energy_kwh_PM1') || 0) + P * dt;\nglobal.set('energy_kwh_PM1', kwh);\nvar out = {P: +P.toFixed(2), Q: +Q.toFixed(2), S: +S.toFixed(2)};\nreturn [\n  {payload: out.P, topic:'P'},\n  {payload: out.Q, topic:'Q'},\n  {payload: out.S, topic:'S'},\n  {payload: +kwh.toFixed(3), topic:'Energy_kWh'}\n];",
        "outputs": 4,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 340,
        "y": 1000,
        "wires": [
            [
                "22186a13716eeabd",
                "27ef8984c9b13f49",
                "605744dc19ff03cb"
            ],
            [
                "197b925dadf03427",
                "851077ef3a71558f",
                "7e802f9c7e5e6081"
            ],
            [
                "1cad21e5782d9054",
                "b14762a956be1d1f",
                "9f718eef643786c2"
            ],
            [
                "762e1360919dea20",
                "d9883673cbdcc2fd"
            ]
        ]
    },
