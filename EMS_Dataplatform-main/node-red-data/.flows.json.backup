    {
        "id": "e08d66dbe7d58088",
        "type": "inject",
        "z": "13228cd659ae2a60",
        "name": "Calc Q,S PM7",
        "props": [
            {
                "p": "payload"
            },
            {
                "p": "topic",
                "vt": "str"
            }
        ],
        "repeat": "5",
        "crontab": "",
        "once": true,
        "onceDelay": "0.5",
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 200,
        "y": 1000,
        "wires": [
            [
                "37e6bb9ff4488f6a"
            ]
        ]
    },
    {
        "id": "37e6bb9ff4488f6a",
        "type": "function",
        "z": "13228cd659ae2a60",
        "name": "PQS PM7",
        "func": "var P  = flow.get('P_7') || 0;\nvar PF = flow.get('PF_7') || 0.9;\nvar S  = PF > 0 ? P / PF : 0;\nvar Q  = Math.sqrt(Math.max(0, S*S - P*P));\n// Calcul énergie consommée (kWh) pour ce PM, dt=5s\nvar dt = 5 / 3600;\nvar kwh = (global.get('energy_kwh_PM7') || 0) + P * dt;\nglobal.set('energy_kwh_PM7', kwh);\nvar out = {P: +P.toFixed(2), Q: +Q.toFixed(2), S: +S.toFixed(2)};\nreturn [\n  {payload: out.P, topic:'P'},\n  {payload: out.Q, topic:'Q'},\n  {payload: out.S, topic:'S'},\n  {payload: +kwh.toFixed(3), topic:'Energy_kWh'}\n];",
        "outputs": 4,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 520,
        "y": 1020,
        "wires": [
            [
                "fb7e7fec668756ad",
                "a677f73b67f0a73d",
                "7082060e7191eae0"
            ],
