        "type": "function",
        "z": "3983825debe3736c",
        "name": "Store PF1",
        "func": "var _pf = (msg.payload||90)/100;\ncontext.set('PF_1', _pf);\nflow.set('PF_1', _pf);\nreturn msg;",
