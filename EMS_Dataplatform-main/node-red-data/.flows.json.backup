        "id": "5faf9a75b3a45588",
        "type": "modbus-client",
        "name": "modbus-sim",
        "clienttype": "tcp",
        "bufferCommands": true,
        "stateLogEnabled": false,
        "queueLogEnabled": false,
        "failureLogEnabled": true,
        "tcpHost": "modbus-sim",
