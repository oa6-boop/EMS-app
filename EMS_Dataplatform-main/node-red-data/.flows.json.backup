        "type": "function",
        "z": "a88fb1713c1d4fee",
        "name": "Store P4",
        "func": "var v = msg.payload || 0;\ncontext.set('P_4', v);\nflow.set('P_4', v);\nflow.set('P_Flotation_4', v);\nglobal.set('P_4', v);\nglobal.set('P_Flotation_4', v);\nreturn msg;",
        "outputs": 1,
