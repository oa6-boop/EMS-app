    {
        "id": "e319d589137b09f7",
        "type": "function",
        "z": "9acf80d30d51b41a",
        "name": "PM3/data",
        "func": "var d={timestamp:new Date().toISOString(),frequency:+(flow.get('pm3_freq')||0).toFixed(3),voltage_L1N:+(flow.get('pm3_vL1N')||0).toFixed(3),voltage_L2N:+(flow.get('pm3_vL2N')||0).toFixed(3),voltage_L3N:+(flow.get('pm3_vL3N')||0).toFixed(3),voltage_L1L2:+(flow.get('pm3_vL1L2')||0).toFixed(3),voltage_L2L3:+(flow.get('pm3_vL2L3')||0).toFixed(3),voltage_L3L1:+(flow.get('pm3_vL3L1')||0).toFixed(3),current_L1:+(flow.get('pm3_iL1')||0).toFixed(3),current_L2:+(flow.get('pm3_iL2')||0).toFixed(3),current_L3:+(flow.get('pm3_iL3')||0).toFixed(3),thd_voltage:+(flow.get('pm3_thdV')||0).toFixed(3),thd_current:+(flow.get('pm3_thdI')||0).toFixed(3),power_factor:+(flow.get('PF_3')||0).toFixed(3),active_power_kW:+(flow.get('pm3_Pkw')||0).toFixed(3),reactive_power_kVAR:+(flow.get('pm3_Q')||0).toFixed(3),apparent_power_kVA:+(flow.get('pm3_S')||0).toFixed(3),energy_consumption_kWh:+(global.get('energy_kwh_PM3')||0).toFixed(3),breaker_status:flow.get('pm3_breaker')||0,alarm_trip:flow.get('pm3_alarm')||0};msg.payload=JSON.stringify(d);return msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 340,
        "y": 2000,
        "wires": [
            [
                "04842541982103c8"
            ]
        ]
    },
