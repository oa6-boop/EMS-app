    {
        "id": "a02839edf7e129d4",
        "type": "inject",
        "z": "a88fb1713c1d4fee",
        "name": "Calc Q,S PM4",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "5",
        "crontab": "",
        "once": true,
        "onceDelay": "0.5",
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 80,
        "y": 865,
        "wires": [
            [
                "794b2f8684ab0be7"
            ]
        ]
    },
    {
        "id": "794b2f8684ab0be7",
        "type": "function",
        "z": "a88fb1713c1d4fee",
        "name": "PQS PM4",
        "func": "var P  = flow.get('P_4') || 0;\nvar PF = flow.get('PF_4') || 0.9;\nvar S  = PF > 0 ? P / PF : 0;\nvar Q  = Math.sqrt(Math.max(0, S*S - P*P));\n// Calcul énergie consommée (kWh) pour ce PM, dt=5s\nvar dt = 5 / 3600;\nvar kwh = (global.get('energy_kwh_PM4') || 0) + P * dt;\nglobal.set('energy_kwh_PM4', kwh);\nvar out = {P: +P.toFixed(2), Q: +Q.toFixed(2), S: +S.toFixed(2)};\nreturn [\n  {payload: out.P, topic:'P'},\n  {payload: out.Q, topic:'Q'},\n  {payload: out.S, topic:'S'},\n  {payload: +kwh.toFixed(3), topic:'Energy_kWh'}\n];",
        "outputs": 4,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 280,
        "y": 865,
        "wires": [
            [
                "28496717632e42ed",
                "60d368896b856b66",
                "e9b801a114bff0c9"
            ],
            [
                "869da0a4ae32ddce",
                "6d3f2b6b8b4e748d",
                "81af710ea5a5939b"
            ],
            [
