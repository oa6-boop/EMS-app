    {
        "id": "e1db9539c315d4ba",
        "type": "function",
        "z": "3983825debe3736c",
        "name": "Acc Tonnage Weigh_Belt_Scale",
        "func": "\nvar dt = 2/3600;\nvar fv = msg.payload || 0;\nvar t  = context.get('tonn_Weigh_Belt_Scale') || 0;\nt += fv * dt;\ncontext.set('tonn_Weigh_Belt_Scale', t);\nflow.set('tonn_Weigh_Belt_Scale', t);\nmsg.instant = fv;\nmsg.payload = +t.toFixed(2);\nreturn msg;\n",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 790,
        "y": 2100,
        "wires": [
            [
                "a24e95297d829597"
            ]
        ]
    },
