        "name": "Acc Tonnage Weigh_Belt_Scale_Output",
        "func": "\nvar dt = 2/3600;\nvar fv = msg.payload || 0;\nvar t  = context.get('tonn_Weigh_Belt_Scale_Output') || 0;\nt += fv * dt;\ncontext.set('tonn_Weigh_Belt_Scale_Output', t);\nflow.set('tonn_Weigh_Belt_Scale_Output', t);\nmsg.instant = fv;\nmsg.payload = +t.toFixed(2);\nreturn msg;\n",
