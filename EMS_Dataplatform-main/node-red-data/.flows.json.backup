    {
        "id": "b532b2b3c430eb4b",
        "type": "inject",
        "z": "ee4d86bc2514176b",
        "name": "Generate Steam/Fuel",
        "props": [
            {
                "p": "payload"
            },
            {
                "p": "topic",
                "vt": "str"
            }
        ],
        "repeat": "5",
        "crontab": "",
        "once": true,
        "onceDelay": "0.5",
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 80,
        "y": 60,
        "wires": [
            [
                "f26aba77f825c70b",
                "2376cc32f74ca5e0",
                "f9f727f1d466fb9e"
            ]
        ]
    },
    {
        "id": "f26aba77f825c70b",
        "type": "function",
        "z": "ee4d86bc2514176b",
        "name": "Gen Steam",
        "func": "var out = {};\nout['Steam_Flow_Rate'] = +Math.max(0, Math.min(20000, 10000 + 800*Math.sin(Date.now()/30000) + 50*(Math.random()-0.5))).toFixed(2);\nout['Steam_Totalizer'] = +Math.max(0, Math.min(1000000, 1000 + 50*Math.sin(Date.now()/30000) + 10*(Math.random()-0.5))).toFixed(2);\nout['Steam_Pressure'] = +Math.max(0, Math.min(25, 20 + 0.5*Math.sin(Date.now()/30000) + 0.2*(Math.random()-0.5))).toFixed(2);\nout['Steam_Temperature'] = +Math.max(100, Math.min(300, 200 + 5*Math.sin(Date.now()/30000) + 1*(Math.random()-0.5))).toFixed(2);\nflow.set('steam_data', out);\nmsg.payload = out; return msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 280,
        "y": 60,
        "wires": [
            [
                "de3799d9f59bef8f",
                "b657e5497b10c222",
                "8eee044d8d07c6c5",
                "81e1b4a3e3f5eadf"
            ]
        ]
    },
