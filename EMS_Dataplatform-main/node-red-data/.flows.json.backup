    {
        "id": "3d54b6914c21eb0e",
        "type": "function",
        "z": "77c6caec778ad665",
        "name": "Calc Total Eau",
        "func": "var v_wash = global.get('vol_Water_Flow_Meter_Inlet')     || 0;\nvar v_flot = global.get('vol_Water_Flow_Meter_Flotation') || 0;\nvar total  = v_wash + v_flot;\nglobal.set('water_total', total);\nreturn [\n  {payload: +v_wash.toFixed(3)},\n  {payload: +v_flot.toFixed(3)},\n  {payload: +total.toFixed(3)}\n];\n",
        "outputs": 3,
        "noerr": 0,
