        "name": "Store P5",
        "func": "var v = msg.payload || 0;\ncontext.set('P_5', v);\nflow.set('P_5', v);\nflow.set('P_Flotation_5', v);\nglobal.set('P_5', v);\nglobal.set('P_Flotation_5', v);\nreturn msg;",
