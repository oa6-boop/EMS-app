    {
        "id": "1b56e70567979180",
        "type": "inject",
        "z": "9acf80d30d51b41a",
        "name": "Calc Q,S PM3",
        "props": [
            {
                "p": "payload"
            },
            {
                "p": "topic",
                "vt": "str"
            }
        ],
        "repeat": "5",
        "crontab": "",
        "once": true,
        "onceDelay": "0.5",
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 80,
        "y": 1060,
        "wires": [
            [
                "bc0d25bd92a84937"
            ]
        ]
    },
    {
        "id": "bc0d25bd92a84937",
        "type": "function",
        "z": "9acf80d30d51b41a",
        "name": "PQS PM3",
        "func": "var P  = flow.get('P_3') || 0;\nvar PF = flow.get('PF_3') || 0.9;\nvar S  = PF > 0 ? P / PF : 0;\nvar Q  = Math.sqrt(Math.max(0, S*S - P*P));\n// Calcul énergie consommée (kWh) pour ce PM, dt=5s\nvar dt = 5 / 3600;\nvar kwh = (global.get('energy_kwh_PM3') || 0) + P * dt;\nglobal.set('energy_kwh_PM3', kwh);\nvar out = {P: +P.toFixed(2), Q: +Q.toFixed(2), S: +S.toFixed(2)};\nreturn [\n  {payload: out.P, topic:'P'},\n  {payload: out.Q, topic:'Q'},\n  {payload: out.S, topic:'S'},\n  {payload: +kwh.toFixed(3), topic:'Energy_kWh'}\n];",
        "outputs": 4,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 300,
        "y": 1020,
        "wires": [
            [
                "6e96763534c23f35",
                "5404ca9d544a3ac5",
                "2cbd915395bfddf8"
            ],
            [
                "757136e506969a31",
