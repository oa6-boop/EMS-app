    {
        "id": "aaae8f239196437a",
        "type": "function",
        "z": "3983825debe3736c",
        "name": "Store P2",
        "func": "var v = msg.payload || 0;\ncontext.set('P_2', v);\nflow.set('P_2', v);\nflow.set('P_EXTRACTION_2', v);\nglobal.set('P_2', v);\nglobal.set('P_EXTRACTION_2', v);\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 790,
        "y": 1770,
        "wires": [
