        "id": "c2b462d1045de6fa",
        "type": "function",
        "z": "b2f38a1c9c4d89a5",
        "name": "PM6/data",
        "func": "var d={timestamp:new Date().toISOString(),frequency:+(flow.get('pm6_freq')||0).toFixed(3),voltage_L1N:+(flow.get('pm6_vL1N')||0).toFixed(3),voltage_L2N:+(flow.get('pm6_vL2N')||0).toFixed(3),voltage_L3N:+(flow.get('pm6_vL3N')||0).toFixed(3),voltage_L1L2:+(flow.get('pm6_vL1L2')||0).toFixed(3),voltage_L2L3:+(flow.get('pm6_vL2L3')||0).toFixed(3),voltage_L3L1:+(flow.get('pm6_vL3L1')||0).toFixed(3),current_L1:+(flow.get('pm6_iL1')||0).toFixed(3),current_L2:+(flow.get('pm6_iL2')||0).toFixed(3),current_L3:+(flow.get('pm6_iL3')||0).toFixed(3),thd_voltage:+(flow.get('pm6_thdV')||0).toFixed(3),thd_current:+(flow.get('pm6_thdI')||0).toFixed(3),power_factor:+(flow.get('PF_6')||0).toFixed(3),active_power_kW:+(flow.get('pm6_Pkw')||0).toFixed(3),reactive_power_kVAR:+(flow.get('pm6_Q')||0).toFixed(3),apparent_power_kVA:+(flow.get('pm6_S')||0).toFixed(3),energy_consumption_kWh:+(global.get('energy_kwh_PM6')||0).toFixed(3),breaker_status:flow.get('pm6_breaker')||0,alarm_trip:flow.get('pm6_alarm')||0};msg.payload=JSON.stringify(d);return msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
