    {
        "id": "280a99c0e169c29c",
        "type": "function",
        "z": "13228cd659ae2a60",
        "name": "PM7/data",
        "func": "var d={timestamp:new Date().toISOString(),frequency:+(flow.get('pm7_freq')||0).toFixed(3),voltage_L1N:+(flow.get('pm7_vL1N')||0).toFixed(3),voltage_L2N:+(flow.get('pm7_vL2N')||0).toFixed(3),voltage_L3N:+(flow.get('pm7_vL3N')||0).toFixed(3),voltage_L1L2:+(flow.get('pm7_vL1L2')||0).toFixed(3),voltage_L2L3:+(flow.get('pm7_vL2L3')||0).toFixed(3),voltage_L3L1:+(flow.get('pm7_vL3L1')||0).toFixed(3),current_L1:+(flow.get('pm7_iL1')||0).toFixed(3),current_L2:+(flow.get('pm7_iL2')||0).toFixed(3),current_L3:+(flow.get('pm7_iL3')||0).toFixed(3),thd_voltage:+(flow.get('pm7_thdV')||0).toFixed(3),thd_current:+(flow.get('pm7_thdI')||0).toFixed(3),power_factor:+(flow.get('PF_7')||0).toFixed(3),active_power_kW:+(flow.get('pm7_Pkw')||0).toFixed(3),reactive_power_kVAR:+(flow.get('pm7_Q')||0).toFixed(3),apparent_power_kVA:+(flow.get('pm7_S')||0).toFixed(3),energy_consumption_kWh:+(global.get('energy_kwh_PM7')||0).toFixed(3),breaker_status:flow.get('pm7_breaker')||0,alarm_trip:flow.get('pm7_alarm')||0};msg.payload=JSON.stringify(d);return msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 340,
        "y": 2000,
        "wires": [
            [
                "252a8add4392c6eb"
            ]
        ]
    },
