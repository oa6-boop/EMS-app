        "func": "var v = msg.payload || 0;\ncontext.set('P_6', v);\nflow.set('P_6', v);\nflow.set('P_Utilities_6', v);\nglobal.set('P_6', v);\nglobal.set('P_Utilities_6', v);\nreturn msg;",
