    {
        "id": "f9f727f1d466fb9e",
        "type": "function",
        "z": "ee4d86bc2514176b",
        "name": "Build Steam_Fuel/data",
        "func": "var steam = flow.get('steam_data') || {};\nvar fuel  = flow.get('fuel_data') || {};\nvar d = {\n  timestamp: new Date().toISOString(),\n  steam: {\n    flow_rate: steam.Steam_Flow_Rate || 0,\n    totalizer: steam.Steam_Totalizer || 0,\n    pressure: steam.Steam_Pressure || 0,\n    temperature: steam.Steam_Temperature || 0\n  },\n  fuel: {\n    flow_rate: fuel.Fuel_Flow_Rate || 0,\n    totalizer: fuel.Fuel_Totalizer || 0,\n    temperature: fuel.Fuel_Temperature || 0,\n    pressure: fuel.Fuel_Pressure || 0\n  }\n};\nmsg.payload = JSON.stringify(d);\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 480,
        "y": 660,
        "wires": [
