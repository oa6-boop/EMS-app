        "z": "e5f153fe05e631db",
        "name": "Q§S CALCULS",
        "func": "var P  = flow.get('P_1') || 0;\nvar PF = flow.get('PF_1') || 0.9;\nvar S  = PF > 0 ? P / PF : 0;\nvar Q  = Math.sqrt(Math.max(0, S*S - P*P));\n// Calcul énergie consommée (kWh) pour ce PM, dt=5s\nvar dt = 5 / 3600;\nvar kwh = (global.get('energy_kwh_PM1') || 0) + P * dt;\nglobal.set('energy_kwh_PM1', kwh);\nvar out = {P: +P.toFixed(2), Q: +Q.toFixed(2), S: +S.toFixed(2)};\nreturn [\n  {payload: out.P, topic:'P'},\n  {payload: out.Q, topic:'Q'},\n  {payload: out.S, topic:'S'},\n  {payload: +kwh.toFixed(3), topic:'Energy_kWh'}\n];",
        "outputs": 4,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 340,
        "y": 1000,
