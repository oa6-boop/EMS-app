    {
        "id": "ed932e081cf42e3f",
        "type": "function",
        "z": "a88fb1713c1d4fee",
        "name": "Acc Volume Water_Flow_Meter_Flotation",
        "func": "var dt = 2/3600;\nvar fv = msg.payload || 0;\nvar v  = context.get('vol_Water_Flow_Meter_Flotation') || 0;\nv += fv * dt;\ncontext.set('vol_Water_Flow_Meter_Flotation', v);\nflow.set('vol_Water_Flow_Meter_Flotation', v);\nglobal.set('vol_Water_Flow_Meter_Flotation', v);\nmsg.instant  = fv;\nmsg.payload  = +v.toFixed(3);\nreturn msg;\n",
        "outputs": 1,
