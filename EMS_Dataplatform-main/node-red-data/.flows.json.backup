    {
        "id": "369955419366227e",
        "type": "inject",
        "z": "b2f38a1c9c4d89a5",
        "name": "Calc Q,S PM6",
        "props": [
            {
                "p": "payload"
            },
            {
                "p": "topic",
                "vt": "str"
            }
        ],
        "repeat": "5",
        "crontab": "",
        "once": true,
        "onceDelay": "0.5",
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 80,
        "y": 920,
        "wires": [
            [
                "5fa5915c1d02b29b"
            ]
        ]
    },
    {
        "id": "5fa5915c1d02b29b",
        "type": "function",
        "z": "b2f38a1c9c4d89a5",
        "name": "PQS PM6",
        "func": "var P  = flow.get('P_6') || 0;\nvar PF = flow.get('PF_6') || 0.9;\nvar S  = PF > 0 ? P / PF : 0;\nvar Q  = Math.sqrt(Math.max(0, S*S - P*P));\n// Calcul énergie consommée (kWh) pour ce PM, dt=5s\nvar dt = 5 / 3600;\nvar kwh = (global.get('energy_kwh_PM6') || 0) + P * dt;\nglobal.set('energy_kwh_PM6', kwh);\nvar out = {P: +P.toFixed(2), Q: +Q.toFixed(2), S: +S.toFixed(2)};\nreturn [\n  {payload: out.P, topic:'P'},\n  {payload: out.Q, topic:'Q'},\n  {payload: out.S, topic:'S'},\n  {payload: +kwh.toFixed(3), topic:'Energy_kWh'}\n];",
        "outputs": 4,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 220,
        "y": 940,
        "wires": [
            [
                "e992d7d4cb4b9a15",
                "74f56eb2bbbb79b0",
                "63c9c869c33cf7fb"
            ],
            [
                "6b51f431210fb742",
                "22e701ec9cb8fefc",
                "2661a74691e80dbd"
            ],
            [
                "c935ddf3ef7c3336",
                "3ea54c85139a0739",
                "2d4bde0ca543dfee"
            ],
            [
                "5073ce43f151da23",
                "4ea9e4c6316a6f78"
            ]
        ]
    },
