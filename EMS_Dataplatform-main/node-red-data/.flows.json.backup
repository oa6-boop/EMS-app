        "func": "var d={timestamp:new Date().toISOString(),frequency:+(flow.get('pm1_freq')||0).toFixed(3),voltage_L1N:+(flow.get('pm1_vL1N')||0).toFixed(3),voltage_L2N:+(flow.get('pm1_vL2N')||0).toFixed(3),voltage_L3N:+(flow.get('pm1_vL3N')||0).toFixed(3),voltage_L1L2:+(flow.get('pm1_vL1L2')||0).toFixed(3),voltage_L2L3:+(flow.get('pm1_vL2L3')||0).toFixed(3),voltage_L3L1:+(flow.get('pm1_vL3L1')||0).toFixed(3),current_L1:+(flow.get('pm1_iL1')||0).toFixed(3),current_L2:+(flow.get('pm1_iL2')||0).toFixed(3),current_L3:+(flow.get('pm1_iL3')||0).toFixed(3),thd_voltage:+(flow.get('pm1_thdV')||0).toFixed(3),thd_current:+(flow.get('pm1_thdI')||0).toFixed(3),power_factor:+(flow.get('PF_1')||0).toFixed(3),active_power_kW:+(flow.get('pm1_Pkw')||0).toFixed(3),reactive_power_kVAR:+(flow.get('pm1_Q')||0).toFixed(3),apparent_power_kVA:+(flow.get('pm1_S')||0).toFixed(3),energy_consumption_kWh:+(global.get('energy_kwh_PM1')||0).toFixed(3),breaker_status:flow.get('pm1_breaker')||0,alarm_trip:flow.get('pm1_alarm')||0};msg.payload=JSON.stringify(d);return msg;",
